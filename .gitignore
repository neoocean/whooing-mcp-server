# Claude Code per-machine settings — do not mirror to GitHub
.claude/settings.local.json

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Secrets
.env
.env.*
!.env.example

# 실 사용자 config (P4 only). .example 만 git 으로.
whooing-mcp.toml
!whooing-mcp.toml.example

# 거래 첨부파일 (개인 금융 supporting docs — GitHub 절대 X).
# 단, attachments/README.md 는 디렉터리 용도 설명 — git + p4 둘 다 commit.
# P4 에는 모든 attachments/ 가 정책상 들어감 (cross-machine).
attachments/*
!attachments/README.md

# SQLite db (queue + annotations) — P4 에는 sync, GitHub 에는 절대 X
# (사용자 정책 2026-05-09: cross-machine via P4 만)
queue.db
whooing-data.sqlite
whooing-data.sqlite-journal
whooing-data.sqlite-wal
whooing-data.sqlite-shm
*.sqlite
*.sqlite3
*.db-journal
*.db-wal
*.db-shm

